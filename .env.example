# Copy this file to .env and fill in your settings

# === Feishu (optional, awaiting credentials) ===
# Option A: Custom robot webhook (simplest)
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxx-xxxx-xxxx-xxxx-xxxx
#
# Option B: App bot (more powerful)
# FEISHU_APP_ID=cli_xxxx
# FEISHU_APP_SECRET=xxxx
#
# When credentials are set, auto-enabled:
# FEISHU_ENABLED=true

# === LLM / NLU (optional — Q&A + intent parsing) ===
# LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-xxxx
# LLM_MODEL=qwen-turbo
# OPENAI_API_KEY=sk-xxxx

# === Database ===
# Set DATABASE_URL to use PostgreSQL (otherwise SQLite at data/db/supply_chain.db)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DATABASE_ECHO=false

# === Cache (optional) ===
# REDIS_URL=redis://localhost:6379/0

# === HTTP client ===
# HTTP_TIMEOUT=15.0
# HTTP_MAX_RETRIES=3

# === Internal API token (set in production to protect admin endpoints) ===
# INTERNAL_API_TOKEN=my-secret-token

# === Logging ===
LOG_LEVEL=INFO

# === Hotness ===
DEEP_PROCESS_TOP_N=20

# === Tavily web-search API (optional — backstops CLS/EastMoney blind spots) ===
# Free tier: 1000 credits/month, 1 credit per basic search.
# Sign up at https://tavily.com
# TAVILY_API_KEY=tvly-xxxx
